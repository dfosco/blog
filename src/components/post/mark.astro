---
interface Props {
  color?: string;
  random?: boolean;
  turn?: boolean;
  block?: boolean;
}

// Color options for the hue
const hueOptions = [
  { hueName: 'gray', value: '1' },
  { hueName: 'yellow', value: '42' },
  { hueName: 'orange', value: '20' },
  { hueName: 'red', value: '5' },
  { hueName: 'purple', value: '272' },
  { hueName: 'blue', value: '210' },
  { hueName: 'green', value: '142' }
];

// Gets a random color
const getRandomHue = () => {
  const randomIndex = Math.floor(Math.random() * hueOptions.length);
  return hueOptions[randomIndex].value;
};

// Gets matching color between color prop and hueOptions
const getMatchingHue = (color?: string) => {
  if (!color) return '42';
  const match = hueOptions.find(option => option.hueName === color);
  return match?.value || '42';
};

const { 
  turn = false, 
  tilt = false, 
  random = false, 
  color,
  hue = random ? getRandomHue() : getMatchingHue(color),
  block = false
} = Astro.props;

// Gets random rotation value to pass into CSS
const rotation = turn ? (Math.random() < 0.5 ? -1 : 1) : 0;

// Gets random shadow Y offset value to pass into CSS
const tilted = tilt ? (Math.random() < 0.5 ? -4 : 4) : 0;
---

<i class={`mark ${block && 'inline-block'}`} data-color={color}>
	<slot />
</i>
<style define:vars={{ 
    hue, 
    rotation: `${rotation}deg`, 
    til: `${tilted}px`,
    sat: `${(color === 'gray' ? '1%' : '96%')}`
}}>

  
	.mark {
    --op: 60%;
    /* outline: 3px solid hsla(var(--hue), var(--sat), 92%, var(--op)); */
    box-shadow: 0 var(--til) 0 4px hsla(var(--hue), var(--sat), 92%, var(--op));
    background-color: hsla(var(--hue), var(--sat), 92%, var(--op));
    color: hsl(var(--hue), var(--sat), 10%);
    font-style: normal;
    transform: rotate(var(--rotation));
    /* display: inline-block; */
    padding: 0 2px;
  }

/* @supports (text-box: trim-both cap alphabetic) {
  .mark {
    outline: none;
    text-box: trim-both cap alphabetic;
    box-shadow: 0 0 0 6px hsla(var(--hue), var(--sat), 92%, var(--op));
  }
} */

  .inline-block {
    margin-bottom: 12px;
    display: block;
    width: fit-content;
  }
</style>
